{
  "name": "appactor-react-native",
  "version": "0.1.2",
  "description": "AppActor React Native SDK — server-authoritative in-app purchase management for iOS and Android.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace appactor-react-native-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "test": "jest"
  },
  "keywords": [
    "appactor",
    "react-native",
    "subscriptions",
    "in-app-purchases",
    "paywalls",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appactor/appactor-react-native.git"
  },
  "author": "AppActor <dev@appactor.com> (https://appactor.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/appactor/appactor-react-native/issues"
  },
  "homepage": "https://github.com/appactor/appactor-react-native#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "base64-js": "^1.5.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@types/react": "^19.2.0",
    "del-cli": "^7.0.0",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.41.0",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": ">=19.2.0",
    "react-native": ">=0.85.0"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "jest"
    ],
    "version": "0.62.0"
  }
}
